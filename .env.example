# ─────────────────────────────────────────────
# Variables de entorno del proyecto SCG-SOA
# Copia este archivo a .env y rellena los valores
# ─────────────────────────────────────────────

# Bus SOA (normalmente no necesitas cambiar esto en Docker)
BUS_HOST=bus
BUS_PORT=5000

# Secreto compartido para autenticar el registro de servicios en el bus.
# Genera un valor largo y aleatorio, p. ej.: openssl rand -hex 32
BUS_SECRET=cambia_esto_por_un_secreto_largo_aleatorio

# Supabase — obtén estos valores en supabase.com > Project Settings > API
SUPABASE_URL=https://tuproyecto.supabase.co

# Clave service_role (PRIVILEGIO TOTAL) — SOLO para los microservicios backend.
# Nunca debe salir del servidor ni incrustarse en el frontend.
SUPABASE_KEY=tu_service_role_key_aqui

# Clave anon (bajo privilegio) — la ÚNICA que puede ir al frontend (VITE_*).
SUPABASE_ANON_KEY=tu_anon_key_aqui

# Orígenes CORS permitidos para el gateway (separados por coma).
# En producción, especifica el dominio real del frontend.
CORS_ORIGINS=http://localhost:5173
